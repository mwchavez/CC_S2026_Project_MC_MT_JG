# ============================================================
# CloudHoney — Environment Variables Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file to .env:  cp .env.example .env
#   2. Fill in the values below with your actual credentials
#   3. NEVER commit .env to Git — it is already in .gitignore
#
# For production/deployed services, these values should live
# in GCP Secret Manager — not in environment variables.
# This file is for LOCAL DEVELOPMENT AND TESTING ONLY.
# ============================================================

# --- GCP Project ---
GCP_PROJECT_ID=cloudhoney-sp26
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# --- Compute Engine (Honeypot VM) ---
HONEYPOT_VM_NAME=cloudhoney-honeypot
HONEYPOT_EXTERNAL_IP=

# --- Cloud Storage ---
GCS_LOG_BUCKET=cloudhoney-logs

# --- Pub/Sub Topics ---
PUBSUB_EVENTS_TOPIC=cloudhoney-events
PUBSUB_ALERTS_TOPIC=cloudhoney-alerts

# --- Firestore ---
FIRESTORE_COLLECTION=events

# --- SendGrid (Email Alerts) ---
# Store this in Secret Manager for deployed Cloud Functions.
# Only use this locally for testing the deliver_alert function.
SENDGRID_API_KEY=your-sendgrid-api-key-here
ALERT_EMAIL_RECIPIENT=team@example.com

# --- Traffic Generator ---
TARGET_URL=http://HONEYPOT_EXTERNAL_IP:5000
